{
  "repositoryUrl": "https://github.com/nikhilrajnair/ng-track-event-directive.git",
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/npm",
      {
        "pkgRoot": "dist/tracking",
        "provenance": true
      }
    ],
    "@semantic-release/github"
  ]
}
