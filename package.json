{
  "name": "ng-track-event-directive",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build tracking",
    "docs:dev": "vitepress dev docs-src --port 4000",
    "docs:build": "vitepress build docs-src",
    "docs:build:pages": "VITEPRESS_BASE=/ng-track-event-directive/ vitepress build docs-src",
    "docs:preview": "vitepress preview docs-src",
    "demo:start": "ng serve demo-app",
    "demo:build": "ng build demo-app --configuration production",
    "demo:build:safe": "CI=1 ng build demo-app --configuration production",
    "build:watch": "ng build tracking --watch --configuration development",
    "test": "ng test tracking --watch=false",
    "test:coverage": "ng test tracking --watch=false --coverage",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "semantic-release": "semantic-release",
    "pack:lib": "cd dist/tracking && npm pack",
    "publish:lib": "cd dist/tracking && npm publish --access public"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || ^26.0.0"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "mixpanel-browser": "^2.78.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "happy-dom": "^20.0.5",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "semantic-release": "^24.2.9",
    "typescript": "~6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  }
}
